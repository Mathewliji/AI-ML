# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# URL of the Ollama service — matches the service name in docker-compose.yml
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── EOL scan defaults ─────────────────────────────────────────────────────────
# Items with fewer than DAYS_WARN days until EOL are flagged CRITICAL
DAYS_WARN=45

# ── Slack (optional) ──────────────────────────────────────────────────────────
# Leave empty to skip Slack notifications
SLACK_WEBHOOK_URL=

# ── Airflow core ──────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-production

# ── Postgres (shared by Airflow metadata DB) ──────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
