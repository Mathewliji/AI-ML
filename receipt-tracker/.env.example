# Set to true to run without any API key (uses realistic fake receipt data)
MOCK_MODE=false

# Anthropic — get yours at https://console.anthropic.com (not needed when MOCK_MODE=true)
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL — use a strong unique password, never commit the real .env
POSTGRES_PASSWORD=change_me_to_something_strong
DATABASE_URL=postgresql://receipts:change_me_to_something_strong@localhost:5432/receipts

# Streamlit → FastAPI (used inside Docker; change to localhost for local dev)
API_URL=http://localhost:8000
UI_ORIGIN=http://localhost:8501
